# Nara AI worker — local config.
# Copy to .env and fill in. NEVER commit real keys.
# The worker reads these via nara_worker/config.py (pydantic-settings).

# ─── Postgres (Supabase) ────────────────────────────────────
# The worker uses the service role connection and scopes every query by user_id.
DATABASE_URL=postgresql://postgres:[password]@db.your-project.supabase.co:5432/postgres

# ─── Groq (LLM inference) ───────────────────────────────────
GROQ_API_KEY=your-groq-key
GROQ_MODEL_FAST=llama-3.1-8b-instant
GROQ_MODEL_QUALITY=llama-3.3-70b-versatile

# ─── OpenAI (embeddings only) ───────────────────────────────
OPENAI_API_KEY=your-openai-key
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ─── Worker loop ────────────────────────────────────────────
WORKER_POLL_INTERVAL_MS=2000
# Entries left in 'processing' longer than this are re-queued by the sweeper.
STUCK_ENTRY_TIMEOUT_SEC=300
# pg-boss schema name (Node side owns creation; default is "pgboss").
PGBOSS_SCHEMA=pgboss
